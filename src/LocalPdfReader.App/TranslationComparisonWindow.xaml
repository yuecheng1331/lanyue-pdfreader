<Window x:Class="LocalPdfReader.App.TranslationComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="对照翻译"
        Icon="Assets/LanyuePDF.ico"
        Width="920"
        Height="620"
        MinWidth="720"
        MinHeight="480">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="20" FontWeight="SemiBold" Text="对照翻译" />
        <ListView Grid.Row="1"
                  Margin="0,12,0,0"
                  ItemsSource="{Binding ComparisonSegments}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#" Width="44" DisplayMemberBinding="{Binding Index}" />
                    <GridViewColumn Header="原文" Width="410">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SourceText}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="译文" Width="410">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TranslatedText}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
