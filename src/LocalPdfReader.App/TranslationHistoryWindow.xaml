<Window x:Class="LocalPdfReader.App.TranslationHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译历史"
        Icon="Assets/LanyuePDF.ico"
        Width="780"
        Height="520"
        MinWidth="620"
        MinHeight="420">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="20" FontWeight="SemiBold" Text="翻译历史" />
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListBox ItemsSource="{Binding HistoryEntries}"
                     SelectedItem="{Binding SelectedHistoryEntry, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,5">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Preview}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="#FF6B7280"
                                       Text="{Binding Summary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <GroupBox Header="原文">
                    <TextBox Margin="8"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding SelectedHistoryEntry.Entry.SourceText}" />
                </GroupBox>
                <GroupBox Grid.Row="1" Margin="0,10,0,0" Header="译文">
                    <TextBox Margin="8"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding SelectedHistoryEntry.Entry.TranslatedText}" />
                </GroupBox>
            </Grid>
        </Grid>
        <WrapPanel Grid.Row="2" Margin="0,12,0,0" HorizontalAlignment="Right">
            <Button Padding="12,6" Command="{Binding LoadSelectedHistoryCommand}">载入</Button>
            <Button Margin="8,0,0,0"
                    Padding="12,6"
                    Command="{Binding MarkHistoryPreferredCommand}">参考样本</Button>
            <Button Margin="8,0,0,0"
                    Padding="12,6"
                    Command="{Binding MarkHistoryRejectedCommand}">避开样本</Button>
            <Button Margin="8,0,0,0"
                    Padding="12,6"
                    Command="{Binding ClearHistorySampleCommand}">取消标记</Button>
            <Button Margin="8,0,0,0"
                    Padding="12,6"
                    Command="{Binding DeleteHistoryEntryCommand}">删除记录</Button>
        </WrapPanel>
    </Grid>
</Window>
