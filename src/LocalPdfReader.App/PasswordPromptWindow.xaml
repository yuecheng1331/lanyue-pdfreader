<Window x:Class="LocalPdfReader.App.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入 PDF 密码"
        Icon="Assets/LanyuePDF.ico"
        Width="360"
        Height="190"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="PasswordPromptWindow_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="SemiBold"
                   Text="{Binding PromptTitle}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,10"
                   Foreground="#FF5D6470"
                   Text="{Binding PromptMessage}"
                   TextWrapping="Wrap" />
        <PasswordBox x:Name="DocumentPasswordBox"
                     Grid.Row="2"
                     Height="30"
                     Padding="6"
                     VerticalAlignment="Top"
                     PasswordChar="●"
                     KeyDown="DocumentPasswordBox_KeyDown" />
        <StackPanel Grid.Row="3"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="76"
                    Padding="10,5"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Content="确定" />
            <Button Width="76"
                    Margin="8,0,0,0"
                    Padding="10,5"
                    IsCancel="True"
                    Content="取消" />
        </StackPanel>
    </Grid>
</Window>
