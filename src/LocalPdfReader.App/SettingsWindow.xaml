<Window x:Class="LocalPdfReader.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译设置"
        Icon="Assets/LanyuePDF.ico"
        Width="560"
        Height="700"
        MinWidth="500"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Loaded="SettingsWindow_Loaded">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding CanEdit}">
            <Button Padding="12,6" Click="DeleteApiKeyButton_Click">删除密钥</Button>
            <Button Margin="8,0,0,0" Padding="12,6" Click="TestConnectionButton_Click">测试连接</Button>
            <Button Margin="8,0,0,0" Padding="12,6" Click="SaveButton_Click">保存</Button>
            <Button Margin="8,0,0,0" Padding="12,6" IsCancel="True">关闭</Button>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="0,16,0,12" Padding="10" Background="#FFF3F4F6">
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="165" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,16" FontSize="20" FontWeight="SemiBold" Text="DeepSeek 翻译设置" />

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="API 地址（OpenAI 兼容）" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4" Padding="6"
                         ToolTip="DeepSeek 官方地址填写 https://api.deepseek.com，不要添加 /anthropic。"
                         Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="模型" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4" Padding="6" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="目标语言" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4" Padding="6" Text="{Binding TargetLanguage, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="默认风格" />
                <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,4" Padding="6"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding DefaultPreset}">
                    <ComboBoxItem Content="直译" Tag="Literal" />
                    <ComboBoxItem Content="流畅" Tag="Fluent" />
                    <ComboBoxItem Content="学术论文" Tag="Academic" />
                    <ComboBoxItem Content="计算机科学" Tag="ComputerScience" />
                    <ComboBoxItem Content="医学" Tag="Medical" />
                    <ComboBoxItem Content="自定义" Tag="Custom" />
                </ComboBox>

                <TextBlock Grid.Row="5" VerticalAlignment="Center" Text="超时时间（秒）" />
                <TextBox Grid.Row="5" Grid.Column="1" Margin="0,4" Padding="6" Text="{Binding TimeoutSeconds}" />

                <TextBlock Grid.Row="6" VerticalAlignment="Center" Text="API 密钥" />
                <PasswordBox x:Name="ApiKeyBox" Grid.Row="6" Grid.Column="1" Margin="0,4" Padding="6" />

                <TextBlock Grid.Row="7" VerticalAlignment="Center" Text="缓存上限（条）" />
                <TextBox Grid.Row="7" Grid.Column="1" Margin="0,4" Padding="6" Text="{Binding MaximumCacheEntries}" />

                <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,8,0,0">
                    <CheckBox Content="允许翻译功能访问网络" IsChecked="{Binding AllowTranslationNetworkAccess}" />
                    <CheckBox Margin="0,8,0,0" Content="使用流式响应" IsChecked="{Binding Stream}" />
                </StackPanel>

                <GroupBox Grid.Row="9" Grid.ColumnSpan="2" Margin="0,14,0,0" Header="会话与历史">
                    <Grid Margin="10,6,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Row="0" Grid.ColumnSpan="2" Content="保存并恢复每个文档的阅读位置" IsChecked="{Binding SaveReadingPosition}" />
                        <CheckBox Grid.Row="1" Margin="0,8,0,0" Content="记录最近打开文件" IsChecked="{Binding RecordRecentDocuments}" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,4,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="最多" />
                            <TextBox Width="42" Margin="6,0" Padding="3" HorizontalContentAlignment="Center" Text="{Binding MaximumRecentDocuments}" />
                            <TextBlock VerticalAlignment="Center" Text="项" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="10" Grid.ColumnSpan="2" Margin="0,14,0,0" Header="快捷键">
                    <Grid Margin="10,6,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="唤起搜索" />
                        <TextBox Grid.Column="1"
                                 Margin="0,3"
                                 Padding="6"
                                 Text="{Binding SearchShortcut, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="翻译选区" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,3"
                                 Padding="6"
                                 Text="{Binding TranslationShortcut, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.ColumnSpan="2"
                                   Margin="0,6,0,0"
                                   Foreground="#FF6B7280"
                                   Text="格式示例：Ctrl+F、Ctrl+Shift+T。Ctrl+C、Ctrl+V 和 Ctrl+S 保留给复制、粘贴和保存批注。"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
