<Window x:Class="LocalPdfReader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LocalPdfReader.App"
        Title="澜阅 PDF" Icon="Assets/LanyuePDF.ico" Height="760" Width="1180"
        MinHeight="560" MinWidth="820"
        Loaded="MainWindow_Loaded"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                Background="#FFF7F8FA"
                BorderBrush="#FFD9DDE5"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Padding="14,6" Click="OpenButton_Click" IsEnabled="{Binding CanOpenDocument}">打开 PDF</Button>
                    <Button Margin="6,0,0,0"
                            Padding="10,6"
                            Click="ReopenClosedTabButton_Click"
                            IsEnabled="{Binding CanReopenClosedTab}"
                            ToolTip="恢复刚关闭的标签">恢复标签</Button>
                </StackPanel>
                <ScrollViewer Grid.Column="1"
                              Margin="10,0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DocumentTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,0"
                                        Padding="2"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        AllowDrop="True"
                                        DragOver="DocumentTab_DragOver"
                                        Drop="DocumentTab_Drop"
                                        ToolTip="{Binding FullPath}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="BorderBrush" Value="#FFCBD0D8" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#FFDCEBFF" />
                                                    <Setter Property="BorderBrush" Value="#FF3A78C2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Button MinWidth="120"
                                                MaxWidth="240"
                                                Padding="10,5"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="DocumentTabButton_Click"
                                                PreviewMouseLeftButtonDown="DocumentTab_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="DocumentTab_PreviewMouseMove">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <Button Width="28"
                                                Margin="2,0,0,0"
                                                Padding="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="CloseDocumentTabButton_Click"
                                                Content="×"
                                                ToolTip="关闭标签" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Menu Grid.Column="2"
                      Padding="0"
                      VerticalAlignment="Center"
                      Background="Transparent">
                    <MenuItem Header="更多">
                        <MenuItem Header="设置" Click="SettingsButton_Click" />
                        <MenuItem Header="关于" Click="AboutButton_Click" />
                    </MenuItem>
                </Menu>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top"
                Padding="8,5"
                Background="White"
                BorderBrush="#FFE3E6EC"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="34"
                        Padding="0,6"
                        Command="{Binding PreviousPageCommand}"
                        ToolTip="上一页">‹</Button>
                <TextBox x:Name="PageNumberTextBox"
                         Margin="6,0,0,0"
                         Width="52"
                         Padding="4,5"
                         HorizontalContentAlignment="Center"
                         IsEnabled="{Binding CanUseDocumentControls}"
                         Text="{Binding PageNumberText, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="PageNumberTextBox_PreviewTextInput"
                         DataObject.Pasting="PageNumberTextBox_Pasting">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding GoToPageCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding PageCountText}" />
                <Button Margin="4,0,0,0"
                        Width="34"
                        Padding="0,6"
                        Command="{Binding NextPageCommand}"
                        ToolTip="下一页">›</Button>
                <Border Margin="10,1" Width="1" Background="#FFD9DDE5" />
                <Button Width="34"
                        Padding="0,6"
                        Command="{Binding ZoomOutCommand}"
                        ToolTip="缩小">−</Button>
                <TextBox Margin="8,0"
                         Width="58"
                         Padding="4,5"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         IsEnabled="{Binding CanUseDocumentControls}"
                         Text="{Binding ZoomText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="输入 100、100% 或 1.25 后按 Enter">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ApplyZoomCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Width="34"
                        Padding="0,6"
                        Command="{Binding ZoomInCommand}"
                        ToolTip="放大">+</Button>
                <Menu Margin="10,0,0,0"
                      Padding="0"
                      VerticalAlignment="Center"
                      Background="Transparent">
                    <MenuItem Header="视图">
                        <MenuItem Header="适合页面" Command="{Binding FitPageCommand}" />
                        <MenuItem Header="适合宽度" Command="{Binding FitWidthCommand}" />
                        <MenuItem Header="旋转" Command="{Binding RotateClockwiseCommand}" />
                        <Separator />
                        <MenuItem Header="单页连续" Command="{Binding SinglePageModeCommand}" />
                        <MenuItem Header="双页" Command="{Binding DoublePageModeCommand}" />
                    </MenuItem>
                </Menu>
                </StackPanel>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Right"
                Width="{Binding TranslationPanelWidth}"
                Padding="16"
                Background="#FFF8F9FB"
                BorderBrush="#FFD9DDE5"
                BorderThickness="1,0,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTranslationPanelOpen}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer DataContext="{Binding Translation}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="翻译" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF5D6470"
                               Text="{Binding SourceScopeText}" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Margin="0,0,0,4" Text="翻译风格" />
                            <ComboBox ItemsSource="{Binding StyleOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedStyleOption, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Margin="0,0,0,4" Text="目标语言" />
                            <ComboBox ItemsSource="{Binding TargetLanguageOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding TargetLanguage}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="当次翻译要求" />
                        <TextBox Margin="0,4,0,0"
                                 Padding="6"
                                 Text="{Binding CustomInstruction, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 ToolTip="仅影响本次翻译，会随当前请求发送。" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="原文（发送前可编辑）" />
                    <Grid>
                        <TextBox Height="132"
                                 Padding="8,8,8,32"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SourceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="复制原文" Command="{Binding CopySourceCommand}" />
                                    <MenuItem Header="复制译文" Command="{Binding CopyTranslationCommand}" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,8,8"
                                Padding="8,3"
                                Click="ExpandSourceTextButton_Click">展开</Button>
                    </Grid>
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF5D6470"
                               Text="{Binding SourceCharacterCountText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="#FF5D6470"
                               Text="{Binding EstimatedUsageText}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,12,0,0">
                        <Button Padding="12,6" Command="{Binding TranslateCommand}">开始翻译</Button>
                        <Button Margin="6,0,0,0" Padding="12,6" Command="{Binding CancelTranslationCommand}">停止</Button>
                        <Button Margin="6,0,0,0" Padding="12,6" Command="{Binding RetryTranslationCommand}">重新翻译</Button>
                    </WrapPanel>

                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF5D6470"
                               Text="{Binding ProgressText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FFC62828"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,12,0,0">
                        <TextBox MinHeight="210"
                                 Padding="8,8,8,32"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding TranslatedText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="复制原文" Command="{Binding CopySourceCommand}" />
                                    <MenuItem Header="复制译文" Command="{Binding CopyTranslationCommand}" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,8,8"
                                Padding="8,3"
                                Click="ExpandTranslatedTextButton_Click">展开</Button>
                    </Grid>
                    <WrapPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                        <Button Padding="12,7" Click="TranslationComparisonButton_Click">对照</Button>
                    </WrapPanel>

                    <WrapPanel Margin="0,14,0,0" HorizontalAlignment="Right">
                        <Button Padding="10,6" Click="TranslationHistoryButton_Click">历史</Button>
                        <Button Margin="6,0,0,0"
                                Padding="10,6"
                                Click="TranslationPreferencesButton_Click">偏好</Button>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border DockPanel.Dock="Right"
                Width="22"
                Background="#FFF3F4F6"
                BorderBrush="#FFD9DDE5"
                BorderThickness="1,0,1,0"
                Cursor="SizeWE"
                MouseLeftButtonDown="RightSidebarHandle_MouseLeftButtonDown"
                MouseMove="RightSidebarHandle_MouseMove"
                MouseLeftButtonUp="RightSidebarHandle_MouseLeftButtonUp"
                ToolTip="点击展开或收起翻译栏；拖动调整宽度">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="‹" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTranslationPanelOpen}" Value="True">
                                <Setter Property="Text" Value="›" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
        <Border DockPanel.Dock="Left"
                Width="{Binding LeftSidebarWidth}"
                Padding="14"
                Background="#FFF8F9FB"
                BorderBrush="#FFD9DDE5"
                BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HasDocument, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DataContext.IsLeftSidebarOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TabControl SelectedIndex="{Binding LeftSidebarIndex, Mode=TwoWay}">
                <TabItem Header="目录">
                    <Grid Margin="8" DataContext="{Binding ActiveNavigation}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="PDF 目录" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,8"
                                   Foreground="#FF5D6470"
                                   Text="{Binding OutlineStatusText}"
                                   TextWrapping="Wrap" />
                        <TreeView Grid.Row="2"
                                  ItemsSource="{Binding OutlineItems}"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Button Margin="0,0,0,5"
                                            Padding="7,5"
                                            HorizontalContentAlignment="Stretch"
                                            Background="White"
                                            BorderBrush="#FFD9DDE5"
                                            IsEnabled="{Binding CanNavigate}"
                                            Click="OutlineItemButton_Click">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#FF2F6FAF"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Foreground="#FF7A808A"
                                                       Text="{Binding PageLabel}" />
                                        </StackPanel>
                                    </Button>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </TabItem>
                <TabItem Header="缩略图">
                    <Grid Margin="8" DataContext="{Binding ActiveNavigation}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="页面缩略图" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,8"
                                   Foreground="#FF5D6470"
                                   Text="缩略图滚动到可见位置时按需生成。"
                                   TextWrapping="Wrap" />
                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Thumbnails}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,10"
                                            Padding="8"
                                            HorizontalContentAlignment="Stretch"
                                            Background="White"
                                            BorderBrush="#FFD9DDE5"
                                            Loaded="ThumbnailButton_Loaded"
                                            Click="ThumbnailButton_Click">
                                        <StackPanel>
                                            <Border MinHeight="120"
                                                    Background="#FFEDEFF3"
                                                    BorderBrush="#FFD9DDE5"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding Image}"
                                                           Stretch="Uniform"
                                                           MaxWidth="150"
                                                           MaxHeight="210" />
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="#FF7A808A"
                                                               Text="正在生成...">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRendering}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <TextBlock Margin="0,6,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding PageLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF4B5563" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentPage}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF2F6FAF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="搜索">
                    <Grid Margin="8" DataContext="{Binding ActiveDocumentTab.Search}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="全文搜索" />
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchQueryTextBox"
                                     Padding="7,6"
                                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding SearchCommand}"
                                    Content="搜索" />
                        </Grid>

                        <WrapPanel Grid.Row="2" Margin="0,9,0,0">
                            <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" IsChecked="{Binding MatchCase}" Content="区分大小写" />
                            <CheckBox VerticalAlignment="Center" IsChecked="{Binding WholeWord}" Content="全词匹配" />
                        </WrapPanel>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="SearchProgressBar"
                                         Height="7"
                                         VerticalAlignment="Center"
                                         Minimum="0"
                                         Maximum="{Binding TotalPages, Mode=OneWay}"
                                         Value="{Binding PagesSearched, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="8,4"
                                    Command="{Binding CancelCommand}"
                                    Content="停止" />
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Margin="0,8,0,8"
                                   Foreground="#FF5D6470"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />

                        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,7"
                                                Padding="10"
                                                HorizontalContentAlignment="Stretch"
                                                Background="White"
                                                BorderBrush="#FFD9DDE5"
                                                Click="SearchResultButton_Click">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="#FF2F6FAF" Text="{Binding PageLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding ContextText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Header="批注">
                    <Grid Margin="8" DataContext="{Binding ActiveDocumentTab.Annotations}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="本地批注" />
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock HorizontalAlignment="Right" Foreground="#FF5D6470" Text="{Binding CountText}" />
                                <CheckBox Margin="0,5,0,0"
                                          IsChecked="{Binding SortByModifiedTime}"
                                          Content="按修改时间" />
                                <Menu Margin="0,6,0,0"
                                      HorizontalAlignment="Right"
                                      Background="Transparent">
                                    <MenuItem Header="PDF写入">
                                        <MenuItem Header="写入当前 PDF"
                                                  Click="SavePdfAnnotationsButton_Click" />
                                        <MenuItem Header="另存为带批注 PDF"
                                                  Click="SaveAsPdfAnnotationsButton_Click" />
                                    </MenuItem>
                                </Menu>
                            </StackPanel>
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,8"
                                   Foreground="#FF5D6470"
                                   Text="{Binding AvailabilityMessage}"
                                   TextWrapping="Wrap" />
                        <Grid Grid.Row="2">
                            <ListBox ItemsSource="{Binding Items}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,9"
                                                Padding="9"
                                                Background="White"
                                                BorderBrush="#FFD9DDE5"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock FontWeight="SemiBold" Foreground="#FF2F6FAF" Text="{Binding PageLabel}" />
                                                    <TextBlock HorizontalAlignment="Right" Foreground="#FF7A808A" FontSize="11" Text="{Binding ModifiedAtText}" />
                                                </Grid>
                                                <TextBlock Margin="0,5,0,0"
                                                           MaxHeight="58"
                                                           Text="{Binding SelectedTextPreview}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap" />
                                                <ComboBox Margin="0,7,0,0"
                                                          ItemsSource="{Binding ColorOptions}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding SelectedColor, Mode=TwoWay}" />
                                                <TextBox Margin="0,7,0,0"
                                                         MinHeight="55"
                                                         MaxHeight="120"
                                                         Padding="6"
                                                         AcceptsReturn="True"
                                                         Text="{Binding DraftNote, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         ToolTip="纯文本笔记" />
                                                <WrapPanel Margin="0,7,0,0">
                                                    <Button Padding="8,4" Click="NavigateAnnotationButton_Click" Content="定位" />
                                                    <Button Margin="5,0,0,0"
                                                            Padding="8,4"
                                                            IsEnabled="{Binding HasUnsavedChanges}"
                                                            Click="SaveAnnotationButton_Click"
                                                            Content="保存修改" />
                                                    <Button Margin="5,0,0,0"
                                                            Padding="8,4"
                                                            Click="DeleteAnnotationButton_Click"
                                                            Content="删除" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#FF7A808A"
                                       Text="当前文档暂无批注。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        <Border DockPanel.Dock="Left"
                Width="22"
                Background="#FFF3F4F6"
                BorderBrush="#FFD9DDE5"
                BorderThickness="1,0,1,0"
                Cursor="SizeWE"
                MouseLeftButtonDown="LeftSidebarHandle_MouseLeftButtonDown"
                MouseMove="LeftSidebarHandle_MouseMove"
                MouseLeftButtonUp="LeftSidebarHandle_MouseLeftButtonUp"
                ToolTip="点击展开或收起左侧栏；拖动调整宽度">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="›" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLeftSidebarOpen}" Value="True">
                                <Setter Property="Text" Value="‹" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
        <Grid>
        <Border Margin="20"
                Padding="12,8"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#FFFFF4CE"
                BorderBrush="#FFE5B454"
                BorderThickness="1"
                CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveDocumentTab.IsExternallyModified}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Foreground="#FF5F4200"
                       Text="{Binding ActiveDocumentTab.ExternalModificationMessage}"
                       TextWrapping="Wrap" />
        </Border>
        <ScrollViewer x:Name="PdfViewport"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch"
                      Background="#555555"
                      SizeChanged="PdfViewport_SizeChanged"
                      ScrollChanged="PdfViewport_ScrollChanged"
                      PreviewMouseWheel="PdfViewport_PreviewMouseWheel">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDocument}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding DocumentPages}"
                          Width="{Binding DocumentCanvasWidth}"
                          Height="{Binding DocumentCanvasHeight}"
                          MinWidth="{Binding ViewportWidth, ElementName=PdfViewport}"
                          MinHeight="{Binding ViewportHeight, ElementName=PdfViewport}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding DisplayLeft}" />
                        <Setter Property="Canvas.Top" Value="{Binding DisplayTop}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="{Binding DisplayWidth}"
                              Height="{Binding DisplayHeight}"
                              Background="#FFFDFDFD"
                              Cursor="IBeam"
                              MouseLeftButtonDown="PageSurface_MouseLeftButtonDown"
                              MouseRightButtonDown="PageSurface_MouseRightButtonDown"
                              MouseMove="PageSurface_MouseMove"
                              MouseLeftButtonUp="PageSurface_MouseLeftButtonUp"
                              MouseLeave="PageSurface_MouseLeave">
                            <Border BorderBrush="#22000000"
                                    BorderThickness="1"
                                    Background="#FFFDFDFD" />
                            <Image Stretch="Uniform" Source="{Binding Image}" />
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#FF7A808A"
                                       Text="{Binding PageNumber, StringFormat=第 {0} 页}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasImage}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Margin="0,8,10,0"
                                       Padding="6,2"
                                       FontSize="12"
                                       Foreground="#FF5A6472"
                                       Background="#CCFFFFFF"
                                       Text="当前页">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentPage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Grid IsHitTestVisible="False">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentPage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ItemsControl ItemsSource="{Binding DataContext.SearchHighlightRectangles, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    Background="#88FFD54F"
                                                    BorderBrush="#FFEA9A00"
                                                    BorderThickness="1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding DataContext.AnnotationHighlightRectangles, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}" Height="{Binding Height}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{Binding Fill}" />
                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmphasized}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#FFE53935" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <Grid IsHitTestVisible="False">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectionPage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ItemsControl ItemsSource="{Binding SelectionRectangles}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    Background="#663A8DFF" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <Canvas Panel.ZIndex="10">
                                <Canvas.Style>
                                    <Style TargetType="Canvas">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectionPage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Canvas.Style>
                                <Border Canvas.Left="{Binding DataContext.SelectionToolbarX, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Canvas.Top="{Binding DataContext.SelectionToolbarY, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Padding="6"
                                        Background="#FAFFFFFF"
                                        BorderBrush="#FF8B929C"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" Opacity="0.3" ShadowDepth="2" />
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSelectionToolbarVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Padding="8,4"
                                                Command="{Binding DataContext.CopySelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="复制" />
                                        <Button Margin="4,0,0,0"
                                                Padding="8,4"
                                                Click="TranslateSelectionButton_Click"
                                                Content="翻译" />
                                        <ComboBox Width="68"
                                                  Margin="4,0,0,0"
                                                  ItemsSource="{Binding DataContext.AnnotationColorOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding DataContext.SelectedAnnotationColor, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                        <Button Margin="4,0,0,0"
                                                Padding="8,4"
                                                Command="{Binding DataContext.CreateHighlightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="高亮" />
                                        <Button Margin="4,0,0,0"
                                                Padding="8,4"
                                                Command="{Binding DataContext.CreateHighlightWithNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="高亮并记笔记" />
                                    </StackPanel>
                                </Border>
                            </Canvas>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <local:RecentDocumentsPanel OpenDocumentRequested="RecentDocumentsPanel_OpenDocumentRequested"
                                    RestoreSessionRequested="RecentDocumentsPanel_RestoreSessionRequested"
                                    RecentDocumentRequested="RecentDocumentsPanel_RecentDocumentRequested"
                                    RemoveRecentDocumentRequested="RecentDocumentsPanel_RemoveRecentDocumentRequested"
                                    ClearRecentDocumentsRequested="RecentDocumentsPanel_ClearRecentDocumentsRequested" />
        </Grid>
    </DockPanel>
</Window>
