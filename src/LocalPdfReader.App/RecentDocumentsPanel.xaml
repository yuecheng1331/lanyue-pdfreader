<UserControl x:Class="LocalPdfReader.App.RecentDocumentsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="36" Background="#FFF4F6F8">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasDocument}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="760" HorizontalAlignment="Center">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="LocalPdfReader" />
                <TextBlock Margin="0,8,0,22" Foreground="#FF5D6470" Text="继续阅读本地 PDF，文件内容不会上传。" />
                <WrapPanel>
                    <Button Width="150" Padding="16,9" Click="OpenDocumentButton_Click" IsEnabled="{Binding CanOpenDocument}" Content="打开 PDF" />
                    <Button Margin="10,0,0,0" Padding="16,9" Click="RestoreSessionButton_Click" IsEnabled="{Binding HasRestorableSession}" Content="恢复上次会话" />
                </WrapPanel>

                <Grid Margin="0,30,0,10">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="最近文件" />
                    <Button HorizontalAlignment="Right" Padding="10,5" Click="ClearRecentDocumentsButton_Click" Content="清空列表" />
                </Grid>

                <TextBlock Margin="0,8" Foreground="#FF6B7280" Text="暂无最近文件。" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecentDocuments.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding RecentDocuments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12" Background="White" BorderBrush="#FFD9DDE5" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" />
                                            <TextBlock Margin="10,0,0,0" Foreground="#FFC62828" Text="{Binding AvailabilityText}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF5D6470" Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280">
                                            <Run Text="{Binding LastOpenedText}" /><Run Text=" · " /><Run Text="{Binding PageText}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Margin="12,0,0,0" Padding="12,6" VerticalAlignment="Center" Click="RecentDocumentButton_Click" IsEnabled="{Binding DataContext.CanOpenDocument, RelativeSource={RelativeSource AncestorType=UserControl}}" Content="打开" />
                                    <Button Grid.Column="2" Margin="8,0,0,0" Padding="10,6" VerticalAlignment="Center" Click="RemoveRecentDocumentButton_Click" Content="移除" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
