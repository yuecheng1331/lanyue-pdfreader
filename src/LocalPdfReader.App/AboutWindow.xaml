<Window x:Class="LocalPdfReader.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 澜阅 PDF"
        Icon="Assets/LanyuePDF.ico"
        Width="620"
        Height="510"
        MinWidth="520"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="26"
                   FontWeight="SemiBold"
                   Text="{Binding ApplicationInfo.ProductName}" />
        <TextBlock Grid.Row="1"
                   Margin="0,4,0,20"
                   Foreground="#FF5D6470"
                   Text="PDF 阅读、批注与翻译助手" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,5" FontWeight="SemiBold" Text="产品版本" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.ProductVersion}" />
            <TextBlock Grid.Row="1" Margin="0,5" FontWeight="SemiBold" Text="构建提交" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.BuildCommit}" />
            <TextBlock Grid.Row="2" Margin="0,5" FontWeight="SemiBold" Text="构建时间" />
            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.BuildTime}" />
            <TextBlock Grid.Row="3" Margin="0,5" FontWeight="SemiBold" Text="PDFium 版本" />
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.PdfiumVersion}" />
            <TextBlock Grid.Row="4" Margin="0,5" FontWeight="SemiBold" Text=".NET 版本" />
            <TextBox Grid.Row="4" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.DotNetVersion}" />
            <TextBlock Grid.Row="5" Margin="0,5" FontWeight="SemiBold" Text="日志目录" />
            <TextBox Grid.Row="5" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.LogDirectory}" />
            <TextBlock Grid.Row="6" Margin="0,5" FontWeight="SemiBold" Text="设置目录" />
            <TextBox Grid.Row="6" Grid.Column="1" Margin="0,2" IsReadOnly="True" BorderThickness="0" Text="{Binding ApplicationInfo.SettingsDirectory}" />
        </Grid>

        <Button Grid.Row="3"
                Margin="0,20,0,0"
                Padding="18,7"
                HorizontalAlignment="Right"
                IsCancel="True"
                Content="关闭" />
    </Grid>
</Window>
