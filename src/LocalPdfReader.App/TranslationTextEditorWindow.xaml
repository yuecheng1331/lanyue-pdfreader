<Window x:Class="LocalPdfReader.App.TranslationTextEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文本编辑"
        Icon="Assets/LanyuePDF.ico"
        Width="760"
        Height="560"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleTextBlock"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBox x:Name="EditorTextBox"
                 Grid.Row="1"
                 Margin="0,12,0,0"
                 Padding="10"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />
        <WrapPanel Grid.Row="2"
                   Margin="0,12,0,0"
                   HorizontalAlignment="Right">
            <Button MinWidth="84"
                    Padding="14,7"
                    Click="SaveButton_Click">确定</Button>
            <Button MinWidth="84"
                    Margin="8,0,0,0"
                    Padding="14,7"
                    IsCancel="True">取消</Button>
        </WrapPanel>
    </Grid>
</Window>
